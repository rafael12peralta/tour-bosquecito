	<!-- ═══════════════════════════════════════
	     INTRO
	═══════════════════════════════════════ -->

	<layer name="intro" type="container" keep="true" width="100%" height="100%" bgcolor="0x000000" bgalpha="0.80" zorder="9999" enabled="true" bgcapture="true" onloaded="on_intro_loaded();" onclick="on_intro_click();">

		<layer name="intro_logo" url="skin/logo.png" align="center" y="-70" scale="0.2" enabled="false" alpha="0" />

		<layer name="intro_guide" url="skin/help_desktop.png" align="center" y="80" scale="1" enabled="false" alpha="0" />

	</layer>

	<!-- ═══════════════════════════════════════
	     ACCIONES DE LA INTRO
	═══════════════════════════════════════ -->

	<action name="on_intro_loaded">
		set(hotspot[spot_nav_1].visible, false);
		delayedcall(2,
			tween(layer[intro_logo].alpha,  1, 1.2);
			tween(layer[intro_guide].alpha, 1, 1.2);
		);
		set(hotspot[spot_nav_1].visible, false);
		set(hotspot[spot_nav_2].visible, false);
	</action>

	<action name="on_intro_click">
		tween(layer[intro].alpha, 0, 0.8);
		set(layer[intro].enabled, false);
		set(hotspot[intro_imagen].visible, true);
		tween(hotspot[intro_imagen].alpha, 1, 1.0);
	</action>

	<action name="on_intro_imagen_click">
		tween(hotspot[intro_imagen].alpha, 0, 0.8);
		delayedcall(0.85, set(hotspot[intro_imagen].visible, false));
		set(hotspot[spot_nav_1].visible, true);
		set(hotspot[spot_nav_2].visible, true);
	</action>

	<!-- ═══════════════════════════════════════
     VISOR DE PLANTAS — layer 2D
	═══════════════════════════════════════ -->

	<layer name="planta_overlay" keep="true" type="container" width="100%" height="100%" bgcolor="0x000000" bgalpha="0.75" visible="false" alpha="0" zorder="9000" bgcapture="true" onclick="cerrarPlanta();" />

	<layer name="planta_img_layer" keep="true" type="image" url="" align="center" width="80%" height="80%" scalemode="fit" visible="false" alpha="0" zorder="9001" onclick="cerrarPlanta();" />

	<!-- ═══════════════════════════════════════
	ACCIONES PLANTAS
	═══════════════════════════════════════ -->

	<action name="mostrarPlanta1">
		set(global.planta_img1, recursos/plantas/oreja-elefante1.jpg);
		set(global.planta_img2, recursos/plantas/oreja-elefante2.jpg);
		set(global.planta_estado, 1);
		set(layer[planta_img_layer].url, get(global.planta_img1));
		set(layer[planta_overlay].visible, true);
		set(layer[planta_img_layer].visible, true);
		tween(layer[planta_overlay].alpha, 1, 0.3);
		tween(layer[planta_img_layer].alpha, 1, 0.3);
		set(layer[planta_img_layer].onclick, siguientePlanta(););
	</action>

	<action name="mostrarPlanta2">
		set(global.planta_img1, recursos/plantas/dianela1.jpg);
		set(global.planta_img2, recursos/plantas/dianela2.jpg);
		set(global.planta_estado, 1);
		set(layer[planta_img_layer].url, get(global.planta_img1));
		set(layer[planta_overlay].visible, true);
		set(layer[planta_img_layer].visible, true);
		tween(layer[planta_overlay].alpha, 1, 0.3);
		tween(layer[planta_img_layer].alpha, 1, 0.3);
		set(layer[planta_img_layer].onclick, siguientePlanta(););
	</action>

	<action name="mostrarPlanta3">
		set(global.planta_img1, recursos/plantas/guano-costa1.jpg);
		set(global.planta_img2, recursos/plantas/guano-costa2.jpg);
		set(global.planta_estado, 1);
		set(layer[planta_img_layer].url, get(global.planta_img1));
		set(layer[planta_overlay].visible, true);
		set(layer[planta_img_layer].visible, true);
		tween(layer[planta_overlay].alpha, 1, 0.3);
		tween(layer[planta_img_layer].alpha, 1, 0.3);
		set(layer[planta_img_layer].onclick, siguientePlanta(););
	</action>

	<action name="mostrarPlanta4">
		set(global.planta_img1, recursos/plantas/giyer-rojo1.jpg);
		set(global.planta_img2, recursos/plantas/giyer-rojo2.jpg);
		set(global.planta_estado, 1);
		set(layer[planta_img_layer].url, get(global.planta_img1));
		set(layer[planta_overlay].visible, true);
		set(layer[planta_img_layer].visible, true);
		tween(layer[planta_overlay].alpha, 1, 0.3);
		tween(layer[planta_img_layer].alpha, 1, 0.3);
		set(layer[planta_img_layer].onclick, siguientePlanta(););
	</action>

	<action name="siguientePlanta">
		if(global.planta_estado == 1,
			set(global.planta_estado, 2);
			set(layer[planta_img_layer].url, get(global.planta_img2));
			set(layer[planta_img_layer].onclick, cerrarPlanta(););
		,
			cerrarPlanta();
		);
	</action>

	<action name="cerrarPlanta">
		tween(layer[planta_overlay].alpha, 0, 0.3);
		tween(layer[planta_img_layer].alpha, 0, 0.3);
		delayedcall(0.35,
			set(layer[planta_overlay].visible, false);
			set(layer[planta_img_layer].visible, false);
		);
	</action>


