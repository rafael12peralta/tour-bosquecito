	<!-- ═══════════════════════════════════════
	     VARIABLES Y ACCIONES DEL CARRUSEL
	═══════════════════════════════════════ -->

	<data name="carrusel" idx="1" total="1" />

	<action name="carrusel_update">
		set(layer[carrusel_img_1].visible, false);
		set(layer[carrusel_img_2].visible, false);
		set(layer[carrusel_img_3].visible, false);
		txtadd(currentimg, 'carrusel_img_', get(carrusel.idx));
		set(layer[get(currentimg)].visible, true);
		tween(layer[get(currentimg)].alpha, 1, 0.25, easeOutQuad);

		set(layer[dot_1].bgalpha, 0.28);
		set(layer[dot_2].bgalpha, 0.28);
		set(layer[dot_3].bgalpha, 0.28);
		set(layer[dot_%get(carrusel.idx)].bgalpha, 1.0);

		set(layer[dot_1].visible, false);
		set(layer[dot_2].visible, false);
		set(layer[dot_3].visible, false);
		if(carrusel.total GE 1, set(layer[dot_1].visible, true));
		if(carrusel.total GE 2, set(layer[dot_2].visible, true));
		if(carrusel.total GE 3, set(layer[dot_3].visible, true));

		if(carrusel.total GT 1,
			set(layer[carrusel_prev].visible, true);
			set(layer[carrusel_next].visible, true);
		,
			set(layer[carrusel_prev].visible, false);
			set(layer[carrusel_next].visible, false);
		);

		copy(local_idx, carrusel.idx);
		copy(local_total, carrusel.total);
		txtadd(layer[carrusel_counter].html, get(local_idx), ' / ', get(local_total));
	</action>

	<action name="carrusel_next">
		txtadd(currentimg, 'carrusel_img_', get(carrusel.idx));
		tween(layer[get(currentimg)].alpha, 0, 0.18, easeInQuad);
		inc(carrusel.idx);
		if(carrusel.idx GT carrusel.total, set(carrusel.idx, 1));
		delayedcall(0.15, carrusel_update());
	</action>

	<action name="carrusel_prev">
		txtadd(currentimg, 'carrusel_img_', get(carrusel.idx));
		tween(layer[get(currentimg)].alpha, 0, 0.18, easeInQuad);
		dec(carrusel.idx);
		if(carrusel.idx LT 1, copy(carrusel.idx, carrusel.total));
		delayedcall(0.15, carrusel_update());
	</action>

	<!-- show_planta: %1=título %2=desc %3=total %4=img1 %5=img2 %6=img3 -->
	<action name="show_planta">
		set(layer[modal_title].html, %1);
		set(layer[modal_desc].html,  %2);

		set(carrusel.idx,   1);
		set(carrusel.total, %3);

		set(layer[carrusel_img_1].url, %4);
		set(layer[carrusel_img_2].url, %5);
		set(layer[carrusel_img_3].url, %6);

		set(layer[carrusel_img_1].alpha, 0);
		set(layer[carrusel_img_2].alpha, 0);
		set(layer[carrusel_img_3].alpha, 0);

		carrusel_update();

		set(layer[planta_modal].visible, true);
		set(layer[planta_modal].alpha,   0);
		set(layer[modal_card].scale,     0.88);
		set(layer[modal_card].alpha,     0);

		tween(layer[planta_modal].alpha, 1,   0.30, easeOutQuad);
		tween(layer[modal_card].scale,   1.0, 0.32, easeOutBack);
		tween(layer[modal_card].alpha,   1,   0.28, easeOutQuad);
	</action>

	<action name="close_planta">
		tween(layer[planta_modal].alpha, 0,    0.22, easeInQuad);
		tween(layer[modal_card].scale,   0.92, 0.20, easeInQuad);
		tween(layer[modal_card].alpha,   0,    0.20, easeInQuad);
		delayedcall(0.25, set(layer[planta_modal].visible, false));
	</action>


